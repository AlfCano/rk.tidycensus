				/>
			</menu>
		</menu>
		<menu
			id="data"
			label="Data"
		>
			<menu
				id="OfficialStatistics"
				label="Official Statistics"
			>
				<entry
					component="cmp_DwnldUSCnssDtDwnldUSCnssD"
				/>
			</menu>
		</menu>
	</hierarchy>

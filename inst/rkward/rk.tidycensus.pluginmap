	priority="medium"
>
	<!--
		this code was generated using the rkwarddev package.
	perhaps don't make changes here, but in the rkwarddev script instead!
	-->
	<dependencies>
		<package
			name="tidycensus"
		/>
		<package
			name="sf"
		/>
		<package
			name="ggplot2"
		/>
		<package
			name="viridis"
		/>
	</dependencies>
	<about
		name="rk.tidycensus"
		shortinfo="Download microdata from US Census Bureau and plot spatial data seamlessly."
		longinfo="Download microdata from US Census Bureau and plot spatial data seamlessly."

	>
		<author
			given="Alfonso"
			family="Cano"
			email="alfonso.cano@correo.buap.mx"
			role="aut, cre"
		/>
	</about>
	<require
		map="rkward::menu"
	/>
	<require
		map="rkward::embedded"
	/>
	<components>
		<component
			id="cmp_DwnldUSCnssDtPltTdyCnssMp"
			label="Plot TidyCensus Map"
			type="standard"
			file="plugins/PlotTidyCensusMap.xml"
		>
		</component>
		<component
			id="cmp_DwnldUSCnssDtDwnldUSCnssD"
			label="Download US Census Data"
